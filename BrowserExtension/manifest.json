{
  "manifest_version": 3,
  "name": "Loci Save",
  "description": "Save the current page, selection, image, link, or X post to your local Loci library.",
  "version": "0.2.0",
  "action": {
    "default_title": "Save to Loci",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:17641/*",
    "http://localhost:17641/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ]
}
