# Copy this file to .env for local development.
# Do not commit real credentials.

# X OAuth 2.0 client ID. This is not the API key and not the bearer token.
LOCI_X_CLIENT_ID=

# Optional LLM support. OpenRouter is used when an API key is present.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional local model override. If Ollama is running, this can point to a local model.
LOCI_LLM_MODEL=

# Optional curl.md website-to-Markdown extraction. URLs are sent to curl.md only when enabled.
LOCI_CURLMD_ENABLED=0
CURLMD_API_KEY=
# LOCI_CURLMD_BASE_URL=https://curl.md

# Optional extraction/conversion helpers.
LOCI_PYTHON=
LOCI_EXTRACT_SCRIPT=
LOCI_LIBREOFFICE=
DOCLING_LIBREOFFICE_CMD=

# Keep this off unless you are intentionally exposing the local API beyond loopback.
LOCI_REMOTE_API=0
